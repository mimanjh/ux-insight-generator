# Anything in here is excluded from the Docker build context.
# Keep this aligned with .gitignore plus a few build-only excludes.

# Python
.venv/
__pycache__/
*.pyc
*.pyo

# Frontend build artifacts and deps — the multi-stage build produces its own
node_modules/
frontend/node_modules/
frontend/dist/

# CLI outputs and dev fixtures — not needed in the container
runs/
test_screenshots/

# Secrets — never embed in the image. Fly secrets inject at runtime.
.env
.env.*

# Version control and editor metadata
.git/
.github/
.vscode/
.idea/
.claude/

# OS noise
.DS_Store
Thumbs.db
